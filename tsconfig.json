{
    // 基本の型チェック設定
    "exclude": ["**/node_modules/**"],

    "compilerOptions": {
        "strict": true,
        "target": "ESNext",
        "lib": ["ESNext"],
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
        "moduleDetection": "force",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "types": ["node"], // Node.jsの型定義を使用
        "allowJs": true, // JSファイルのimportを許可する
        "checkJs": false, // 現時点ではJSファイルは型チェック対象外とする
        "noEmit": true, // tscは型チェックのみを行う
        "allowImportingTsExtensions": true, // TypeScriptファイルをimportする際に拡張子.tsを使用する
        "resolveJsonModule": true, // JSONファイルのimportを許可する
        "isolatedModules": true, // export typeを明示的に書く
        "esModuleInterop": false, // default importを厳密に行うためfalseにする
        "forceConsistentCasingInFileNames": true, // ファイル名の大文字小文字を区別する
        "allowSyntheticDefaultImports": false, // default importを厳密に行う

        "noUnusedLocals": true, // 未使用変数はエラー
        "noUnusedParameters": true, // 未使用引数はエラー
        "allowUnusedLabels": false, // 未使用ラベルはエラー
        "noImplicitReturns": true, // returnの書き忘れを検出
        "noFallthroughCasesInSwitch": true, // switch-caseのbreak忘れを検出
        "allowUnreachableCode": false, // 到達できないコードはエラー
        "noUncheckedIndexedAccess": true, // プロパティアクセスを厳密にする
        "skipLibCheck": true, // .d.tsファイルは型チェックしない
        "noErrorTruncation": true // エラーメッセージを省略しない
    }
}
